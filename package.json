{
  "name": "local-clipboard-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local-first clipboard vault for saving, searching, and encrypting snippets in the browser.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/w0nderful666/open-tools-starter"
  },
  "homepage": "https://w0nderful666.github.io/open-tools-starter/",
  "keywords": [
    "github-pages",
    "frontend",
    "local-first",
    "no-backend",
    "privacy-friendly",
    "vite",
    "react",
    "typescript",
    "clipboard",
    "vault",
    "web-crypto"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "tsc -b",
    "preview": "vite preview",
    "self-test": "node scripts/run-self-test.mjs",
    "preflight": "node scripts/preflight.mjs",
    "release:check": "npm run preflight",
    "test:all": "npm run build && npm run self-test && npm run preflight",
    "test:ci": "npm run test:all"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "engines": {
    "node": ">=18"
  }
